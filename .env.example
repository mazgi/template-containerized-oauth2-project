# -------------------------------------------------------
# backend
# -------------------------------------------------------

# PostgreSQL connection string for Prisma.
DATABASE_URL=postgresql://postgres:password@db:5432/localauth

# Port the NestJS server listens on.
PORT=4000

# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://example.com).
# Defaults to http://localhost:3000 if not set.
CORS_ORIGIN=http://localhost:3000,http://web-app:3000

# -------------------------------------------------------
# JWT Authentication
# Generate strong secrets with: openssl rand -base64 32
# Use distinct values for JWT_SECRET and JWT_REFRESH_SECRET.
# -------------------------------------------------------

# Secret used to sign access tokens.
JWT_SECRET=change-me-access-secret

# Secret used to sign refresh tokens (must differ from JWT_SECRET).
JWT_REFRESH_SECRET=change-me-refresh-secret

# Lifetime of an access token (e.g. 15m, 1h).
JWT_ACCESS_EXPIRATION=15m

# Lifetime of a refresh token (e.g. 7d, 30d).
JWT_REFRESH_EXPIRATION=7d

# -------------------------------------------------------
# Apple Sign In
# Create credentials at https://developer.apple.com/
# Certificates, Identifiers & Profiles → Identifiers → Service IDs
# Create a Key with "Sign in with Apple" capability and download the .p8 file.
# Add both callback URLs below to Return URLs:
#   http://localhost:4000/auth/apple/callback
#   http://localhost:4000/auth/apple/native/callback
# -------------------------------------------------------

# Service ID registered in Apple Developer Account.
APPLE_CLIENT_ID=change-me-apple-client-id

# Your Apple Developer Team ID (10 characters).
APPLE_TEAM_ID=change-me-apple-team-id

# Key ID of the Sign in with Apple key.
APPLE_KEY_ID=change-me-apple-key-id

# Contents of the .p8 private key file (replace actual newlines with \n).
APPLE_PRIVATE_KEY=change-me-apple-private-key

# The callback URL registered in Apple Developer Account (web flow).
APPLE_CALLBACK_URL=http://localhost:4000/auth/apple/callback

# The callback URL registered in Apple Developer Account (native app flow: iOS/macOS/Android).
APPLE_NATIVE_CALLBACK_URL=http://localhost:4000/auth/apple/native/callback

# -------------------------------------------------------
# Discord OAuth2
# Create credentials at https://discord.com/developers/applications
# OAuth2 → Redirects → add both callback URLs:
#   http://localhost:4000/auth/discord/callback
#   http://localhost:4000/auth/discord/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from the Discord Developer Portal.
DISCORD_CLIENT_ID=change-me-discord-client-id

# OAuth2 Client Secret from the Discord Developer Portal.
DISCORD_CLIENT_SECRET=change-me-discord-client-secret

# The callback URL registered in the Discord Developer Portal (web flow).
DISCORD_CALLBACK_URL=http://localhost:4000/auth/discord/callback

# The callback URL registered in the Discord Developer Portal (native app flow: iOS/macOS/Android/Windows).
DISCORD_NATIVE_CALLBACK_URL=http://localhost:4000/auth/discord/native/callback

# -------------------------------------------------------
# GitHub OAuth2
# Create credentials at https://github.com/settings/developers
# New OAuth App → set Homepage URL and Authorization callback URL:
#   http://localhost:4000/auth/github/callback
#   http://localhost:4000/auth/github/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from GitHub Developer Settings.
GH_CLIENT_ID=change-me-github-client-id

# OAuth2 Client Secret from GitHub Developer Settings.
GH_CLIENT_SECRET=change-me-github-client-secret

# The callback URL registered in GitHub OAuth App (web flow).
GH_CALLBACK_URL=http://localhost:4000/auth/github/callback

# The callback URL registered in GitHub OAuth App (native app flow: iOS/macOS/Android).
GH_NATIVE_CALLBACK_URL=http://localhost:4000/auth/github/native/callback

# -------------------------------------------------------
# Google OAuth2
# Create credentials at https://console.cloud.google.com/
# APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add both callback URLs below to Authorized redirect URIs:
#   http://localhost:4000/auth/google/callback
#   http://localhost:4000/auth/google/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from Google Cloud Console.
GOOGLE_CLIENT_ID=change-me-google-client-id

# OAuth2 Client Secret from Google Cloud Console.
GOOGLE_CLIENT_SECRET=change-me-google-client-secret

# The callback URL registered in Google Cloud Console (web flow).
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# The callback URL registered in Google Cloud Console (native app flow: iOS/macOS/Android).
GOOGLE_NATIVE_CALLBACK_URL=http://localhost:4000/auth/google/native/callback

# -------------------------------------------------------
# X (Twitter) OAuth2
# Create credentials at https://developer.twitter.com/
# App Settings → User authentication settings → OAuth 2.0
# Set Type of App to "Web App, Automated App or Bot"
# Add both Callback URIs below to Callback URI / Redirect URL:
#   http://localhost:4000/auth/twitter/callback
#   http://localhost:4000/auth/twitter/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from the Twitter Developer Portal.
TWITTER_CLIENT_ID=change-me-twitter-client-id

# OAuth2 Client Secret from the Twitter Developer Portal.
TWITTER_CLIENT_SECRET=change-me-twitter-client-secret

# The callback URL registered in the Twitter Developer Portal (web flow).
TWITTER_CALLBACK_URL=http://localhost:4000/auth/twitter/callback

# The callback URL registered in the Twitter Developer Portal (native app flow: iOS/macOS/Android).
TWITTER_NATIVE_CALLBACK_URL=http://localhost:4000/auth/twitter/native/callback

# Secret used to sign session cookies (required for Twitter OAuth2 PKCE).
SESSION_SECRET=change-me-session-secret

# -------------------------------------------------------
# OAuth2 (shared across all providers)
# -------------------------------------------------------

# The frontend URL to redirect to after successful OAuth2 authentication (web).
FRONTEND_URL=http://localhost:3000

# Custom URL scheme used to redirect back to native apps after OAuth2.
# Must match the callbackURLScheme used in iOS/macOS (ASWebAuthenticationSession)
# and the intent-filter scheme in Android (AndroidManifest.xml).
NATIVE_APP_URL_SCHEME=oauth2app
