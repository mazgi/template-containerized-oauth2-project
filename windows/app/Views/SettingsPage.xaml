<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="app.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            HorizontalAlignment="Center"
            Width="400"
            Padding="24"
            Spacing="16">

            <TextBlock
                x:Name="ErrorText"
                Foreground="Red"
                Visibility="Collapsed"
                TextWrapping="Wrap" />

            <!-- Email -->
            <TextBlock
                Text="Email"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,16,0,0" />

            <StackPanel
                x:Name="EmailStatusPanel"
                Orientation="Horizontal"
                Spacing="8">
                <TextBlock
                    x:Name="EmailAddressText"
                    VerticalAlignment="Center" />
                <Border
                    x:Name="EmailBadge"
                    CornerRadius="10"
                    Padding="8,2,8,2"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="EmailBadgeText"
                        FontSize="11"
                        FontWeight="Medium" />
                </Border>
            </StackPanel>

            <Button
                x:Name="ResendVerificationButton"
                Content="Resend verification email"
                Click="ResendVerificationButton_Click"
                Visibility="Collapsed"
                AutomationProperties.AutomationId="settings_resendVerification" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="EmailInput"
                    PlaceholderText="Enter new email address"
                    InputScope="EmailSmtpAddress"
                    AutomationProperties.AutomationId="settings_emailTextField" />
                <DropDownButton
                    x:Name="EmailDropdown"
                    Grid.Column="1"
                    Content="&#xE70D;"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    Visibility="Collapsed"
                    AutomationProperties.AutomationId="settings_emailDropdown">
                    <DropDownButton.Flyout>
                        <MenuFlyout x:Name="EmailMenuFlyout" />
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button
                    x:Name="SaveEmailButton"
                    Grid.Column="2"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SaveEmailButton_Click"
                    AutomationProperties.AutomationId="settings_saveEmail" />
            </Grid>

            <!-- Linked Accounts -->
            <TextBlock
                Text="Linked Accounts"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,24,0,0" />

            <!-- Apple -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Apple" VerticalAlignment="Center" />
                <Button
                    x:Name="AppleButton"
                    Grid.Column="1"
                    Click="AppleButton_Click"
                    AutomationProperties.AutomationId="settings_appleButton" />
            </Grid>

            <!-- Discord -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Discord" VerticalAlignment="Center" />
                <Button
                    x:Name="DiscordButton"
                    Grid.Column="1"
                    Click="DiscordButton_Click"
                    AutomationProperties.AutomationId="settings_discordButton" />
            </Grid>

            <!-- GitHub -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="GitHub" VerticalAlignment="Center" />
                <Button
                    x:Name="GithubButton"
                    Grid.Column="1"
                    Click="GithubButton_Click"
                    AutomationProperties.AutomationId="settings_githubButton" />
            </Grid>

            <!-- Google -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Google" VerticalAlignment="Center" />
                <Button
                    x:Name="GoogleButton"
                    Grid.Column="1"
                    Click="GoogleButton_Click"
                    AutomationProperties.AutomationId="settings_googleButton" />
            </Grid>

            <!-- X (Twitter) -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="X (Twitter)" VerticalAlignment="Center" />
                <Button
                    x:Name="TwitterButton"
                    Grid.Column="1"
                    Click="TwitterButton_Click"
                    AutomationProperties.AutomationId="settings_twitterButton" />
            </Grid>

            <!-- Theme -->
            <TextBlock
                Text="Theme"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,24,0,0" />

            <StackPanel
                x:Name="ThemePicker"
                Orientation="Horizontal"
                Spacing="8"
                AutomationProperties.AutomationId="settings_themePicker">
                <RadioButton
                    x:Name="ThemeSystemButton"
                    Content="System"
                    GroupName="Theme"
                    Click="ThemeButton_Click"
                    Tag="System"
                    AutomationProperties.AutomationId="theme_system" />
                <RadioButton
                    x:Name="ThemeLightButton"
                    Content="Light"
                    GroupName="Theme"
                    Click="ThemeButton_Click"
                    Tag="Light"
                    AutomationProperties.AutomationId="theme_light" />
                <RadioButton
                    x:Name="ThemeDarkButton"
                    Content="Dark"
                    GroupName="Theme"
                    Click="ThemeButton_Click"
                    Tag="Dark"
                    AutomationProperties.AutomationId="theme_dark" />
            </StackPanel>

            <!-- Delete Account -->
            <TextBlock
                Text="Delete Account"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,24,0,0" />

            <TextBlock
                Text="Permanently delete your account and all associated data. This action cannot be undone."
                TextWrapping="Wrap"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Margin="0,4,0,0" />

            <Button
                x:Name="DeleteAccountButton"
                Content="Delete Account"
                Click="DeleteAccountButton_Click"
                Foreground="Red"
                BorderBrush="Red"
                AutomationProperties.AutomationId="settings_deleteAccountButton"
                Margin="0,8,0,0" />

        </StackPanel>
    </ScrollViewer>
</Page>
