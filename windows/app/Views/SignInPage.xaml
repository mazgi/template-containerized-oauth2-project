<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="app.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <!-- Sign In Form -->
            <StackPanel
                x:Name="SignInPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="360"
                Padding="24"
                Spacing="16">

                <FontIcon Glyph="&#xE72E;" FontSize="64" HorizontalAlignment="Center" Margin="0,32,0,0" />

                <TextBlock
                    x:Uid="SignInTitle"
                    Style="{StaticResource TitleTextBlockStyle}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    x:Name="ErrorText"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    AutomationProperties.AutomationId="signin_errorText" />

                <TextBox
                    x:Name="EmailBox"
                    x:Uid="SignInEmailBox"
                    InputScope="EmailSmtpAddress"
                    AutomationProperties.AutomationId="signin_emailTextBox" />

                <PasswordBox
                    x:Name="PasswordBox"
                    x:Uid="SignInPasswordBox"
                    PasswordRevealMode="Peek"
                    KeyDown="PasswordBox_KeyDown"
                    AutomationProperties.AutomationId="signin_passwordBox" />

                <HyperlinkButton
                    x:Name="ForgotPasswordLink"
                    x:Uid="ForgotPasswordLink"
                    HorizontalAlignment="Right"
                    Click="ForgotPasswordLink_Click"
                    AutomationProperties.AutomationId="signin_forgotPasswordButton" />

                <TextBlock
                    x:Name="ResetSentText"
                    x:Uid="PasswordResetSentSignIn"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    AutomationProperties.AutomationId="signin_resetSentText" />

                <Button
                    x:Name="SignInButton"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="SignInButton_Click"
                    AutomationProperties.AutomationId="signin_submitButton" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                    <Border Height="1" Width="80" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center" />
                    <TextBlock x:Uid="OrDivider" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                    <Border Height="1" Width="80" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <Button
                    x:Uid="SignInAppleButton"
                    HorizontalAlignment="Stretch"
                    Click="AppleButton_Click"
                    AutomationProperties.AutomationId="signin_appleButton" />

                <Button
                    x:Uid="SignInDiscordButton"
                    HorizontalAlignment="Stretch"
                    Click="DiscordButton_Click"
                    AutomationProperties.AutomationId="signin_discordButton" />

                <Button
                    x:Uid="SignInGitHubButton"
                    HorizontalAlignment="Stretch"
                    Click="GitHubButton_Click"
                    AutomationProperties.AutomationId="signin_githubButton" />

                <Button
                    x:Uid="SignInGoogleButton"
                    HorizontalAlignment="Stretch"
                    Click="GoogleButton_Click"
                    AutomationProperties.AutomationId="signin_googleButton" />

                <Button
                    x:Uid="SignInXButton"
                    HorizontalAlignment="Stretch"
                    Click="TwitterButton_Click"
                    AutomationProperties.AutomationId="signin_xButton" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,8,0,32">
                    <TextBlock x:Uid="NoAccountText" VerticalAlignment="Center" />
                    <HyperlinkButton x:Uid="GoToSignUpLink" Click="SignUpLink_Click"
                                    AutomationProperties.AutomationId="signin_goToSignUpButton" />
                </StackPanel>

            </StackPanel>

            <!-- MFA Challenge Form -->
            <StackPanel
                x:Name="MfaPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="360"
                Padding="24"
                Spacing="16"
                Visibility="Collapsed">

                <FontIcon Glyph="&#xE8D7;" FontSize="64" HorizontalAlignment="Center" Margin="0,32,0,0" />

                <TextBlock
                    x:Uid="MfaTitle"
                    Style="{StaticResource TitleTextBlockStyle}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    x:Uid="MfaPromptText"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <TextBlock
                    x:Name="MfaErrorText"
                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    AutomationProperties.AutomationId="mfa_errorText" />

                <TextBox
                    x:Name="MfaCodeBox"
                    x:Uid="SignInMfaCodeBox"
                    InputScope="Number"
                    MaxLength="8"
                    KeyDown="MfaCodeBox_KeyDown"
                    AutomationProperties.AutomationId="mfa_codeTextBox" />

                <Button
                    x:Name="MfaVerifyButton"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="MfaVerifyButton_Click"
                    AutomationProperties.AutomationId="mfa_verifyButton" />

                <TextBlock
                    x:Uid="MfaRecoveryHint"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    FontSize="12"
                    Margin="0,8,0,0" />

                <HyperlinkButton
                    x:Uid="MfaBackLink"
                    HorizontalAlignment="Center"
                    Click="MfaBackButton_Click"
                    AutomationProperties.AutomationId="mfa_backButton" />

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
