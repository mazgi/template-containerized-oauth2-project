<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="app.Views.SignInPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Width="360"
            Padding="24"
            Spacing="16">

            <FontIcon Glyph="&#xE72E;" FontSize="64" HorizontalAlignment="Center" Margin="0,32,0,0" />

            <TextBlock
                Text="Sign In"
                Style="{StaticResource TitleTextBlockStyle}"
                HorizontalAlignment="Center" />

            <TextBlock
                x:Name="ErrorText"
                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"
                Visibility="Collapsed"
                AutomationProperties.AutomationId="signin_errorText" />

            <TextBox
                x:Name="EmailBox"
                Header="Email"
                PlaceholderText="email@example.com"
                InputScope="EmailSmtpAddress"
                AutomationProperties.AutomationId="signin_emailTextBox" />

            <PasswordBox
                x:Name="PasswordBox"
                Header="Password"
                PlaceholderText="Password"
                PasswordRevealMode="Peek"
                KeyDown="PasswordBox_KeyDown"
                AutomationProperties.AutomationId="signin_passwordBox" />

            <Button
                x:Name="SignInButton"
                Content="Sign In"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}"
                Click="SignInButton_Click"
                AutomationProperties.AutomationId="signin_submitButton" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <Border Height="1" Width="80" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center" />
                <TextBlock Text="or" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                <Border Height="1" Width="80" Background="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center" />
            </StackPanel>

            <Button
                Content="Sign in with Apple"
                HorizontalAlignment="Stretch"
                Click="AppleButton_Click"
                AutomationProperties.AutomationId="signin_appleButton" />

            <Button
                Content="Sign in with Discord"
                HorizontalAlignment="Stretch"
                Click="DiscordButton_Click"
                AutomationProperties.AutomationId="signin_discordButton" />

            <Button
                Content="Sign in with GitHub"
                HorizontalAlignment="Stretch"
                Click="GitHubButton_Click"
                AutomationProperties.AutomationId="signin_githubButton" />

            <Button
                Content="Sign in with Google"
                HorizontalAlignment="Stretch"
                Click="GoogleButton_Click"
                AutomationProperties.AutomationId="signin_googleButton" />

            <Button
                Content="Sign in with X"
                HorizontalAlignment="Stretch"
                Click="TwitterButton_Click"
                AutomationProperties.AutomationId="signin_xButton" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,8,0,32">
                <TextBlock Text="Don't have an account?" VerticalAlignment="Center" />
                <HyperlinkButton Content="Sign Up" Click="SignUpLink_Click"
                                AutomationProperties.AutomationId="signin_goToSignUpButton" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
