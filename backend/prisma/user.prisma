model User {
  id             String                @id @default(cuid(2))
  email          String                @unique
  name           String?
  passwordHash   String?
  preferences    Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  items          Item[]
  socialApple    SocialAccountApple?
  socialGithub   SocialAccountGithub?
  socialGoogle   SocialAccountGoogle?
  socialTwitter  SocialAccountTwitter?
  socialDiscord  SocialAccountDiscord?
}
