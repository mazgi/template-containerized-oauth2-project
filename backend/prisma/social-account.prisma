model SocialAccount {
  id         String   @id @default(cuid(2))
  provider   String
  providerId String
  email      String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@unique([provider, userId])
}
