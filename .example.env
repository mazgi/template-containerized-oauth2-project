# GitHub Actions Variables & Local Configuration (non-sensitive)
# Copy to .env for local development, or to .staging.env / .production.env for CI.
# See docs/ci.md for the env file naming convention.

# -------------------------------------------------------
# Container user
# Prevents node_modules and .pnpm-store from being created with root ownership.
# Set these to your host user's UID/GID: run `id -u` and `id -g` to get them.
# -------------------------------------------------------
UID=1000
GID=1000

# -------------------------------------------------------
# Backend configuration
# -------------------------------------------------------

# Port the NestJS server listens on.
PORT=4000

# Comma-separated list of allowed CORS origins (e.g. http://localhost:3000,https://example.com).
# Defaults to http://localhost:3000 if not set.
CORS_ORIGIN=http://localhost:3000,http://web:3000

# Lifetime of an access token (e.g. 15m, 1h).
AUTH_JWT_ACCESS_EXPIRATION=15m

# Lifetime of a refresh token (e.g. 7d, 30d).
AUTH_JWT_REFRESH_EXPIRATION=7d

# -------------------------------------------------------
# SMTP (email)
# Local development uses Mailpit (SMTP on port 1025, UI on http://localhost:8025).
# For production, set these to your SMTP provider (e.g. SES, SendGrid).
# -------------------------------------------------------

# SMTP server hostname.
# For Amazon SES: email-smtp.{region}.amazonaws.com
SMTP_HOST=mailpit

# SMTP server port.
# For Amazon SES: 587 (STARTTLS) or 465 (TLS Wrapper).
SMTP_PORT=1025

# Use implicit TLS (port 465). Set to false for STARTTLS (port 587).
# Mailpit and STARTTLS use false; TLS Wrapper (port 465) uses true.
SMTP_SECURE=false

# SMTP username (for Amazon SES: IAM SMTP credential username).
# Not needed for local Mailpit.
#SMTP_USER=

# From address for outgoing emails.
# For Amazon SES: must be a verified identity (email or domain).
SMTP_FROM=noreply@localhost

# -------------------------------------------------------
# Apple Sign In
# Create credentials at https://developer.apple.com/
# Certificates, Identifiers & Profiles → Identifiers → Service IDs
# Create a Key with "Sign in with Apple" capability and download the .p8 file.
# Register callback URLs in the Apple Developer Console (Return URLs):
#   {AUTH_CALLBACK_BASE_URL}/auth/apple/callback
#   {AUTH_NATIVE_CALLBACK_BASE_URL}/auth/apple/native/callback
# -------------------------------------------------------

# Service ID registered in Apple Developer Account.
AUTH_APPLE_CLIENT_ID=change-me-apple-client-id

# Your Apple Developer Team ID (10 characters).
AUTH_APPLE_TEAM_ID=change-me-apple-team-id

# Key ID of the Sign in with Apple key.
AUTH_APPLE_KEY_ID=change-me-apple-key-id

# -------------------------------------------------------
# Discord OAuth2
# Create credentials at https://discord.com/developers/applications
# OAuth2 → Redirects → add callback URLs:
#   {AUTH_CALLBACK_BASE_URL}/auth/discord/callback
#   {AUTH_NATIVE_CALLBACK_BASE_URL}/auth/discord/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from the Discord Developer Portal.
AUTH_DISCORD_CLIENT_ID=change-me-discord-client-id

# -------------------------------------------------------
# GitHub OAuth2
# Create credentials at https://github.com/settings/developers
# New OAuth App → set Authorization callback URL:
#   {AUTH_CALLBACK_BASE_URL}/auth/github/callback
# -------------------------------------------------------

# OAuth2 Client ID from GitHub Developer Settings.
AUTH_GITHUB_CLIENT_ID=change-me-github-client-id

# -------------------------------------------------------
# Google OAuth2
# Create credentials at https://console.cloud.google.com/
# APIs & Services → Credentials → OAuth 2.0 Client IDs
# Add callback URLs to Authorized redirect URIs:
#   {AUTH_CALLBACK_BASE_URL}/auth/google/callback
#   {AUTH_NATIVE_CALLBACK_BASE_URL}/auth/google/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from Google Cloud Console.
AUTH_GOOGLE_CLIENT_ID=change-me-google-client-id

# -------------------------------------------------------
# X (Twitter) OAuth2
# Create credentials at https://developer.twitter.com/
# App Settings → User authentication settings → OAuth 2.0
# Set Type of App to "Web App, Automated App or Bot"
# Add callback URLs to Callback URI / Redirect URL:
#   {AUTH_CALLBACK_BASE_URL}/auth/twitter/callback
#   {AUTH_NATIVE_CALLBACK_BASE_URL}/auth/twitter/native/callback
# -------------------------------------------------------

# OAuth2 Client ID from the Twitter Developer Portal.
AUTH_TWITTER_CLIENT_ID=change-me-twitter-client-id

# -------------------------------------------------------
# OAuth2 (shared across all providers)
# -------------------------------------------------------

# Base URL used to construct OAuth2 callback URLs.
# The backend appends /auth/{provider}/callback (or /auth/{provider}/native/callback).
# Local: http://localhost:4000 (backend direct).
# Staging/Production (web): FRONTEND_URL/backend (via reverse proxy, keeps session cookies).
# Staging/Production (native): direct backend URL (native apps connect directly).
AUTH_CALLBACK_BASE_URL=http://localhost:4000
AUTH_NATIVE_CALLBACK_BASE_URL=http://localhost:4000

# The frontend URL to redirect to after successful OAuth2 authentication (web).
FRONTEND_URL=http://localhost:3000

# Custom URL scheme used to redirect back to native apps after OAuth2.
# Must match the callbackURLScheme used in iOS/macOS (ASWebAuthenticationSession)
# and the intent-filter scheme in Android (AndroidManifest.xml).
NATIVE_APP_URL_SCHEME=oauth2app

# -------------------------------------------------------
# Cloud provider CLI profiles (used by the iac container)
# The iac container mounts ~/.aws, ~/.azure, and ~/.config/gcloud as read-only.
# Set the profile/environment variables below so Terraform can locate your credentials.
# -------------------------------------------------------

# AWS SSO profile name. Run `aws configure list-profiles` to list available profiles.
# Required when using AWS SSO (`aws sso login --profile <name>`).
# Leave commented out if using long-lived IAM credentials (~/.aws/credentials).
#AWS_PROFILE=

# -------------------------------------------------------
# AWS
# -------------------------------------------------------

# IAM role ARN with GitHub OIDC trust policy (used for IaC and production image push).
AWS_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/github-actions-iac

# S3 bucket name for Terraform state storage.
AWS_TF_STATE_BUCKET=my-terraform-state

# AWS region where the S3 state bucket is located.
AWS_TF_STATE_REGION=us-east-1

# AWS region for resource deployment (may differ from AWS_TF_STATE_REGION).
AWS_REGION=us-east-1

# -------------------------------------------------------
# Azure
# -------------------------------------------------------

# Resource group that contains the Terraform state storage account.
AZURE_TF_STATE_RESOURCE_GROUP=terraform-state-rg

# Storage account name for Terraform state (must be globally unique).
AZURE_TF_STATE_STORAGE_ACCOUNT=myterraformstate

# Azure region for the Terraform state storage account.
AZURE_TF_STATE_LOCATION=eastus

# Azure location for resource deployment (may differ from AZURE_TF_STATE_LOCATION).
AZURE_LOCATION=eastus

# Azure AD application (service principal) client ID for OIDC authentication.
ARM_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Azure AD tenant ID.
ARM_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure subscription ID.
ARM_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# -------------------------------------------------------
# Google Cloud
# -------------------------------------------------------

# GCS bucket name for Terraform state storage.
GOOGLE_TF_STATE_BUCKET=my-terraform-state

# GCS bucket location (e.g. us, eu, asia).
GOOGLE_TF_STATE_LOCATION=us

# Google Cloud project ID (used for IaC and production image push).
GOOGLE_PROJECT_ID=my-gcp-project

# Google Cloud region (optional, defaults to us-central1).
GOOGLE_REGION=us-central1

# Google Cloud zone (optional, defaults to us-central1-a).
GOOGLE_ZONE=us-central1-a

# Workload Identity Federation provider resource name for OIDC authentication.
GOOGLE_WORKLOAD_IDENTITY_PROVIDER=projects/123456789/locations/global/workloadIdentityPools/github/providers/github

# Google Cloud service account email for GitHub Actions to impersonate.
GOOGLE_SERVICE_ACCOUNT=github-actions@my-gcp-project.iam.gserviceaccount.com

# -------------------------------------------------------
# Terraform variables
# All TF_VAR_* mappings are derived automatically via
# compose.yaml (iac service environment) and GitHub Actions workflows.
# -------------------------------------------------------

# Unique prefix for all cloud resource names (e.g. ECR repos, resource groups, Cloud Run services).
APP_UNIQUE_ID=oauth2-app

# Base domain for DNS and service URLs.
# Service URLs are derived as: https://{web,backend}.{app_unique_id}-{provider}.{domain}
BASE_DOMAIN_NAME=example.com

# Container image tag for the ephemeral layer (optional, defaults to latest).
# Registry URLs are derived from the persistent layer's Terraform outputs.
# IMAGE_TAG=latest
