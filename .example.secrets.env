# Secrets (sensitive values)
# Copy to .secrets.env for local development, or to .staging.secrets.env / .production.secrets.env for CI.
# See docs/ci.md for the env file naming convention.
# See also .example.env for non-sensitive variables and OAuth2 provider setup instructions.

# -------------------------------------------------------
# backend
# -------------------------------------------------------

# PostgreSQL connection string for Prisma.
DATABASE_URL=postgresql://postgres:password@db:5432/localauth

# -------------------------------------------------------
# JWT Authentication
# Generate strong secrets with: openssl rand -base64 32
# Use distinct values for AUTH_JWT_SECRET and AUTH_JWT_REFRESH_SECRET.
# -------------------------------------------------------

# Secret used to sign access tokens.
AUTH_JWT_SECRET=change-me-access-secret

# Secret used to sign refresh tokens (must differ from AUTH_JWT_SECRET).
AUTH_JWT_REFRESH_SECRET=change-me-refresh-secret

# -------------------------------------------------------
# Apple Sign In
# -------------------------------------------------------

# Contents of the .p8 private key file (replace actual newlines with \n).
AUTH_APPLE_PRIVATE_KEY=change-me-apple-private-key

# -------------------------------------------------------
# Discord OAuth2
# -------------------------------------------------------

# OAuth2 Client Secret from the Discord Developer Portal.
AUTH_DISCORD_CLIENT_SECRET=change-me-discord-client-secret

# -------------------------------------------------------
# GitHub OAuth2
# -------------------------------------------------------

# OAuth2 Client Secret from GitHub Developer Settings.
AUTH_GITHUB_CLIENT_SECRET=change-me-github-client-secret

# -------------------------------------------------------
# Google OAuth2
# -------------------------------------------------------

# OAuth2 Client Secret from Google Cloud Console.
AUTH_GOOGLE_CLIENT_SECRET=change-me-google-client-secret

# -------------------------------------------------------
# X (Twitter) OAuth2
# -------------------------------------------------------

# OAuth2 Client Secret from the Twitter Developer Portal.
AUTH_TWITTER_CLIENT_SECRET=change-me-twitter-client-secret

# Secret used to sign session cookies (required for Twitter OAuth2 PKCE).
AUTH_SESSION_SECRET=change-me-session-secret

# -------------------------------------------------------
# SMTP Authentication
# Required for external SMTP providers (e.g. Amazon SES).
# Not needed for local Mailpit. Generate SES SMTP credentials via IAM.
# -------------------------------------------------------

# SMTP password (for Amazon SES: IAM SMTP credential password).
#SMTP_PASS=

# -------------------------------------------------------
# Terraform (sensitive)
# Register with: gh secret set --env Staging --env-file .secrets.env
# -------------------------------------------------------

# Database password for ephemeral Cloud SQL / RDS / PostgreSQL Flexible Server.
TF_VAR_database_password=change-me-database-password
